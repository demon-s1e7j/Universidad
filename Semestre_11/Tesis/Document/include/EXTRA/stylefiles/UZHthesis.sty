%
% MAKETITLE FOR UZH IPZ MA THESIS
%
\def\maketitle{
  \ifenglish
  \begin{titlepage}
    \thispagestyle{empty}
    {
      \setlength{\baselineskip}{8mm}
      \titlepagefont
      \begin{center}
        \vfill
        {\huge\bfseries{\titlestring}}
        \vfill
        {\large
          A thesis submitted to attain the degree of\linebreak
          \textbf{\degreestring}
          \vfill
          Submitted by\linebreak
          \expandafter{\authorstring}
          \vfill
          \acatitlestring
          \vfill
          Supervisors \linebreak
          \examinerstring\linebreak
          \coexaminerstring\linebreak
          \coexaminertwostring
          \ifdefequal{\draftdatestring}{\emptystring}{\vfill\number\year}{\vfill\draftdatestring}
          \ifdefequal{\doinumberstring}{\emptystring}{}{\vfill\doinumberstring}
        }
      \end{center}
      \uzhlogoplace
      \hypersetup{
        pdfauthor={\authorstring},
        pdftitle={\titlestring},
        pdfsubject={Master Thesis}
      }
      \cleardoublepage
    }
  \end{titlepage}
  \fi
}

%%%%%%%%  ADDING FUNCTIONALITY TO SET Z-LEVEL
\pgfkeys{
  /tikz/on layer/.code={
    \pgfonlayer{#1}\begingroup
    \aftergroup\endpgfonlayer
    \aftergroup\endgroup
  },
  /tikz/node on layer/.code={
    \gdef\node@@on@layer{%
      \setbox\tikz@tempbox=\hbox\bgroup\pgfonlayer{#1}\unhbox\tikz@tempbox\endpgfonlayer\egroup}
    \aftergroup\node@on@layer
  },
  /tikz/end node on layer/.code={
    \endpgfonlayer\endgroup\endgroup
  }
}

\def\node@on@layer{\aftergroup\node@@on@layer}
\def\doinumberstring{}

