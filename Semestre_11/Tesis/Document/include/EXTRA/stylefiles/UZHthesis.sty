% -------------------------------------------------------------
% Unnumbered chapter macro for UZH template
% -------------------------------------------------------------
\newcommand{\unnumberedchapter}[1]{%
  \chapter*{#1}
  \thispagestyle{plain}
  \markboth{#1}{#1}
  \addcontentsline{toc}{chapter}{#1}
  \pagestyle{fancy}
}

% -------------------------------------------------------------
% Unnumbered pseudo-chapter for lists (LOT/LOF)
% -------------------------------------------------------------
\newcommand{\unnumberedlistchapter}[2]{%
  \phantomsection
  \addcontentsline{toc}{chapter}{#1}%
  \markboth{#1}{#1}%
  #2%
  \thispagestyle{plain}%
  \cleardoublepage
  \pagestyle{fancy}
}

