%
% REDEFINE TITLES TO SF
%
\@ifclasswith{book}{sfelements}{
  \pagestyle{fancy}
  \fancyhf{}
  \fancyfoot[C]{\sffamily\thepage}

  \fancyhead[L]{}
  \fancyhead[C]{}
  \fancyhead[R]{}

  \fancyfoot[L]{}
  \fancyfoot[C]{\sffamily\thepage}
  \fancyfoot[R]{}

  \fancyhead[OL]{\sffamily\nouppercase{\rightmark}}
  \fancyhead[RE]{\sffamily\nouppercase{\leftmark}}

  \fancyhead[OL]{\normalfont\nouppercase{\rightmark}}
  \fancyhead[RE]{\normalfont\nouppercase{\leftmark}}

  % patch epigraph footer
  \xpatchcmd{\epigraphhead}
    {\def\@oddfoot{\reset@font\hfil\thepage\hfil}}
    {\def\@oddfoot{\reset@font\hfil\sffamily\thepage\hfil}}{}


\renewcommand{\@endpart}{\thispagestyle{plain}\@epipart}

  %% redefine titles 
  % -------------------------------------------------------------
  %  chapters title-only, no 'Chapter', no number
  % -------------------------------------------------------------
  \usepackage{titlesec}
  \titleformat{\chapter}[display]
    {\normalfont\sffamily\huge\bfseries}
    {}         % no Chapter label
    {0pt}
    {\Huge}    % title formatting
  % -------------------------------------------------------------

  \renewcommand{\captionlabelfont}{\small\bfseries\sffamily}
  \renewcommand{\captionfont}{\small}

  \contentsmargin[1cm]{0cm}

  \titlecontents{part}[0em]{\vskip8pt\bfseries\sffamily\large}
    {\contentslabel{1em}\enspace}{}
    {\hspace*{\fill}\contentspage\hspace*{.8mm}}[\vskip 0pt]

  \titlecontents{chapter}[1em]{\vskip8pt\bfseries\sffamily}
    {\contentslabel{1em}\enspace}{}
    {\hfill\contentspage}[\vskip 0pt]

  \titlecontents{section}[3em]{\sffamily}
    {\contentslabel{1.5em}\enspace}{}
    {\hspace{2mm}\titlerule*[1pc]{.}\quad\contentspage}[\vskip 0pt]

  \titlecontents{subsection}[5em]{\filleft\sffamily}
    {\contentslabel{2.2em}\enspace}{}
    {\hspace{2mm}\titlerule*[1pc]{.}\quad\contentspage}[\vskip 0pt]

  \titlecontents{subsubsection}[7em]{\sffamily}
    {\contentslabel{2.5em}\enspace}{}
    {\hspace{2mm}\titlerule*[1pc]{.}\quad\contentspage}[\vskip 0pt]

  \setlist[itemize]{label=\scriptsize\faPlay,labelsep=4mm}
  \setlist[enumerate,1]{label=\sffamily\bfseries\arabic*,labelsep=4mm}
  \setlist[enumerate,2]{label=\sffamily\bfseries\alph*,labelsep=4mm}
  \setlist[enumerate,3]{label=\sffamily\bfseries\roman*,labelsep=4mm}
  \setlist[enumerate,4]{label=\sffamily\bfseries\Alph*,labelsep=4mm}
  \setlist[description]{font=\sffamily}

  \renewcommand{\@pnumwidth}{1.55em}

  \dottedcontents{section}[3.8em]{\normalfont\sffamily\normalsize}{2.3em}{1pc}
  \dottedcontents{subsection}[6.1em]{\normalfont\sffamily\normalsize}{3.2em}{1pc}

  \dottedcontents{figure}[3.2em+.5em]{\normalfont\sffamily\normalsize}{3.2em}{1pc}
  \dottedcontents{table}[3.2em+.5em]{\normalfont\sffamily\normalsize}{3.2em}{1pc}

  \tikzset{every picture/.style={/utils/exec={\sffamily}}}

  \def\th@plain{
    \thm@notefont{\normalfont}
    \thm@headfont{\sf\bfseries}
    \itshape
  }
  \def\th@definition{
    \thm@notefont{\normalfont}
    \thm@headfont{\sf\bfseries}
    \normalfont
  }

}{

  \fancyhf{}
  \fancyhead[OL]{\rightmark}
  \fancyhead[OR]{\thepage}
  \fancyhead[LE]{\thepage}
  \fancyhead[RE]{\leftmark}

  \renewcommand\sfdefault{cmbr}

  \long\def\@makecaption#1#2{
    \vskip 10pt
    \setbox\@tempboxa\hbox{{\bf #1: } #2}
    \ifdim \wd\@tempboxa >\hsize \unhbox\@tempboxa\par
    \else \hbox to\hsize{\hfil\box\@tempboxa\hfil}
    \fi}

  \let\@epipart\@endpart
  \renewcommand{\@endpart}{\thispagestyle{epigraph}\@epipart}
}


